# =====================
# LSM6DSM Example defaults
# =====================

# Enable TinyUSB stack for CDC-ACM (USB virtual serial port)
CONFIG_TINYUSB=y
CONFIG_TINYUSB_CDC_ENABLED=y

# Disable UART console output since we use USB CDC
# (ESP logs will be redirected to USB CDC via esp_log_set_vprintf)
CONFIG_ESP_CONSOLE_NONE=y
# If the above is not available as single-select, use UART default anyway:
# CONFIG_ESP_CONSOLE_UART_DEFAULT=y
# CONFIG_ESP_CONSOLE_USB_CDC=y  # alternative for chips that support native USB CDC

# Compiler optimizations
CONFIG_COMPILER_OPTIMIZATION_DEFAULT=y